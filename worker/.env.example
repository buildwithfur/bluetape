CONVEX_SITE_URL=https://your-deployment.convex.site
RECIPE_WORKER_SECRET=replace-with-a-long-random-secret
OPENROUTER_API_KEY=
OPENROUTER_RECIPE_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
TRANSCRIPTION_PROVIDER=local
LOCAL_WHISPER_MODEL=base
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
WORKER_POLL_SECONDS=5
MAX_VIDEO_SECONDS=1800
MAX_DOWNLOAD_BYTES=157286400
MAX_VISUAL_FRAMES=12
# Optional DataImpulse HTTP proxy. The job ID replaces {session}, keeping one
# residential IP for the import (DataImpulse `sessid`) after a direct request is blocked.
# DATAIMPULSE_PROXY_URL=http://login__sessid.{session}:password@gw.dataimpulse.com:823
