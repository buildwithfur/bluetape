# Created automatically for a development deployment by `npx convex dev`.
CONVEX_DEPLOYMENT=

# Public browser endpoints. VITE_* values are bundled into frontend code and
# must never contain passwords, API keys, or other secrets.
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Server-only Convex deployment variables used by typed-content translation.
# These lines document the expected names; configure their real values with
# `npx convex env set`, not in `.env.local`. The model override is optional.
#
# npx convex env set OPENROUTER_API_KEY
# npx convex env set OPENROUTER_TRANSLATION_MODEL
OPENROUTER_API_KEY=
OPENROUTER_TRANSLATION_MODEL=deepseek/deepseek-v4-flash
